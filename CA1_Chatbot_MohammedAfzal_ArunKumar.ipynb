    "    st.markdown(f\"**Dine Mode:** {(hist.get('dining_mode') or '—').replace('_', ' ').title()}\")\n",
    "    st.markdown(f\"**Payment:** {(hist.get('payment_mode') or '—').replace('_', ' ').title()}\")\n",
    "\n",
    "    cart = hist.get(\"cart\", [])\n",
    "    if cart:\n",
    "        st.markdown(\"**Cart:**\")\n",
    "        menu_prices = REST_KB.get(\"menu\", {})\n",
    "        running_total = 0.0\n",
    "        for item in cart:\n",
    "            name = item[\"item\"]\n",
    "            qty = item[\"qty\"]\n",
